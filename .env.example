# Banco (Compose: host do serviço é `db`)
DATABASE_URL=postgresql://postgres:postgres@db:5432/english_study

POSTGRES_DB=english_study
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

APP_ENV=development
DOCKERHUB_USERNAME=seu-usuario
APP_VERSION=latest

# IA opcional — deixe vazio para usar apenas o gerador local (mock)
AI_PROVIDER=
AI_API_KEY=
# Exemplos: gpt-4o-mini (OpenAI) ou claude-3-5-haiku-20241022 (Anthropic)
AI_MODEL=gpt-4o-mini
# Opcional: base customizada compatível com OpenAI Chat Completions
AI_BASE_URL=

# true = usa IA para corrigir respostas (se AI_PROVIDER + AI_API_KEY existirem); false = só regra local
USE_AI_CORRECTION=true

# Upload PDF (opcional — padrões já funcionam sem definir)
# UPLOAD_DIR=uploads
# MAX_PDF_BYTES=15728640
# MAX_EXTRACTED_CHARS=200000
# DEFAULT_DECK_SIZE=8
# MAX_DECK_SIZE=20
